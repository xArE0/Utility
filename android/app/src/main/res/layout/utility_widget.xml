<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/widget_glass_bg"
    android:gravity="center_vertical"
    android:paddingHorizontal="14dp"
    android:paddingVertical="14dp">

    <!-- App Launcher Button (Leftmost) -->
    <ImageView
        android:id="@+id/btn_launch_app"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginEnd="10dp"
        android:clickable="true"
        android:focusable="true"/>

    <!-- AQI and Weather -->
    <TextView
        android:id="@+id/widget_aqi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="Air Quality: --"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingStart="4dp" />

    <!-- RIGHT SECTION: Timers -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <!-- Button 5m -->
        <FrameLayout
            android:id="@+id/btn_5m_root"
            android:layout_width="44dp"
            android:layout_height="40dp"
            android:background="@drawable/timer_btn_bg"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/btn_5m_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="5m"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />
            <ImageView
                android:id="@+id/btn_5m_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check_white"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Button 15m -->
        <FrameLayout
            android:id="@+id/btn_15m_root"
            android:layout_width="44dp"
            android:layout_height="40dp"
            android:background="@drawable/timer_btn_bg"
            android:layout_marginEnd="6dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/btn_15m_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="15m"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />
            <ImageView
                android:id="@+id/btn_15m_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check_white"
                android:visibility="gone" />
        </FrameLayout>

        <!-- Button 30m -->
        <FrameLayout
            android:id="@+id/btn_30m_root"
            android:layout_width="44dp"
            android:layout_height="40dp"
            android:background="@drawable/timer_btn_bg"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/btn_30m_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="30m"
                android:textColor="#F8FAFC"
                android:textSize="14sp"
                android:textStyle="bold" />
            <ImageView
                android:id="@+id/btn_30m_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check_white"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

</LinearLayout>
